# Knights local environment example
#
# NOTE
# - Applications read OS environment variables (no built-in .env loader).
# - Local helper scripts may optionally load this file and then override
#   per-process values (e.g., ports) when running multiple instances.

# --- Core infrastructure ---
# PostgreSQL
DB_URI=postgresql://knights:password@127.0.0.1:5432/knights_db

# Redis (redis-plus-plus URI format)
REDIS_URI=tcp://127.0.0.1:6379

# --- server_app ---
# Listen port (argv[1] overrides this)
PORT=5000

# Instance Registry heartbeat (Redis)
SERVER_ADVERTISE_HOST=127.0.0.1
# SERVER_ADVERTISE_PORT=5000
SERVER_HEARTBEAT_INTERVAL=5
SERVER_REGISTRY_PREFIX=gateway/instances/
SERVER_REGISTRY_TTL=30
# SERVER_INSTANCE_ID=server-local-1

# Redis behavior
# REDIS_CHANNEL_PREFIX=knights/dev/
USE_REDIS_PUBSUB=0
REDIS_USE_STREAMS=1
PRESENCE_CLEAN_ON_START=0

# Metrics
# IMPORTANT: METRICS_PORT is per-process. If you run multiple components on one
# machine, set different values per terminal/script.
# METRICS_PORT=9100

# --- gateway_app ---
GATEWAY_LISTEN=0.0.0.0:6000
GATEWAY_ID=gateway-default

# gateway_app reads the same registry prefix/ttl variables as server_app.
# SERVER_REGISTRY_PREFIX=gateway/instances/
# SERVER_REGISTRY_TTL=30

# Auth (default is ALLOW_ANONYMOUS=1)
ALLOW_ANONYMOUS=1
# AUTH_PROVIDER=
# AUTH_ENDPOINT=
