@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if("@SERVER_USE_HEADER_ONLY_BOOST_SYSTEM@" STREQUAL "ON")
    find_dependency(Boost CONFIG REQUIRED)
else()
    find_dependency(Boost CONFIG REQUIRED COMPONENTS system)
endif()

find_dependency(Protobuf REQUIRED)
find_dependency(OpenSSL REQUIRED)

find_package(lz4 CONFIG QUIET)
if (NOT TARGET lz4::lz4)
    find_package(PkgConfig REQUIRED)
    pkg_check_modules(LZ4 REQUIRED IMPORTED_TARGET liblz4)
    if (NOT TARGET lz4::lz4)
        add_library(lz4::lz4 INTERFACE IMPORTED)
        if (TARGET PkgConfig::LZ4)
            target_link_libraries(lz4::lz4 INTERFACE PkgConfig::LZ4)
        else()
            target_include_directories(lz4::lz4 INTERFACE ${LZ4_INCLUDE_DIRS})
            target_link_libraries(lz4::lz4 INTERFACE ${LZ4_LIBRARIES})
        endif()
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/server_coreTargets.cmake")

check_required_components(server_core)
